// [CONFIG] Auto Version
// .github/actions/auto-version/configs.jsonc
{
    "ignore_objects": [
        { "name": ".vscode", "type": "dir" },
        { "name": ".gitignore", "type": "file" },
        { "name": ".github", "type": "dir" },
        { "name": ".git", "type": "dir" },
        { "name": "VERSION.md", "type": "file"}
    ],
    "commits_review": 10
}
